{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::combo-raw",
        "arn:aws:s3:::combo-artifacts",
        "arn:aws:s3:::combo-exports",
        "arn:aws:s3:::combo-experience"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:ListMultipartUploadParts",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::combo-raw/*",
        "arn:aws:s3:::combo-artifacts/*",
        "arn:aws:s3:::combo-exports/*",
        "arn:aws:s3:::combo-experience/*"
      ]
    }
  ]
}
