{
  "name": "@cb/runtime",
  "version": "0.0.0",
  "private": true,
  "description": "试用端 runtime：能力项的「播放器」——按 capabilities.storage_key 从 MinIO 加载 CapabilityDefinition 注入 pi agent，带会话管理的流式对话 + 类 Claude Artifacts 产物画布。只依赖 @cb/shared，绝不 import authoring。",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit false",
    "typecheck:test": "tsc -p tsconfig.vitest.json",
    "dev": "node --experimental-strip-types --watch src/index.ts",
    "start": "node dist/index.js",
    "start:api": "node dist/processes/api.js",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@ag-ui/core": "0.0.57",
    "@ag-ui/encoder": "0.0.57",
    "@aws-sdk/client-s3": "^3.726.1",
    "@cb/shared": "workspace:*",
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "jose": "^5.10.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@ag-ui/client": "0.0.57",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
