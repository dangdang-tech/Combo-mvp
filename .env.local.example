# 本机直跑用环境变量（O-02/O-04 · 无 Docker，API 在宿主、走 host-published 端口）。
# 复制为 .env 后按需填。Logto/MinIO/PG 都按 localhost 访问（与 compose 网络无关）。
# 另有 .env.compose.example：全栈 compose 起栈用（按 compose 服务名访问，issuer=logto:3001）。
#
# 两类消费者：(1) Node 进程（apps/api 的 env.ts 校验，见各行「[app]」）；(2) docker-compose 变量替换（见「[compose]」）。
# 本机直跑只用到 [app] 行；[compose] 行本文件留作清单参考（直跑不经 compose）。

# ───────────────────────── 进程通用 [app] ─────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# PROCESS：一镜像四入口分叉（本地直跑可忽略；按需 api|worker|consumer|sweeper）。 [compose]
PROCESS=api

# ───────────────────────── PostgreSQL ─────────────────────────
# [app] 业务进程连接串（业务库 agora）。本机直跑走 localhost:5432。
# ⚠️ 密钥占位：下方 agora:agora 仅本机 dev 占位；起 compose（= 生产栈）改用 .env.compose.example 并填强密钥。
DATABASE_URL=postgres://agora:agora@localhost:5432/agora

# ───────────────────────── Redis 双实例（70 §8.1）─────────────────────────
# [app] redis_queue：BullMQ（noeviction+AOF）；redis_hot：Streams/锁/限流（maxmemory+LRU）
# 本机直跑：两实例分别 6379 / 6380。
REDIS_QUEUE_URL=redis://localhost:6379/0
REDIS_HOT_URL=redis://localhost:6380/0

# ───────────────────────── ObjectStore / MinIO（70 §8.2，四桶）─────────────────────────
# [app] 本机直跑走 localhost:9000。
# ⚠️ 密钥占位：minioadmin 仅本机 dev 占位；compose（生产栈）禁用，详见 .env.compose.example。
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ───────────────────────── Logto 自托管（10 §9 / B-08）─────────────────────────
# [app] 鉴权中间件校验用：issuer + jwks + 回调域名 + application 凭据。
# 角色映射（10 §6.1，Codex#7）：Logto 侧给账号配 creator/consumer 业务角色；评审运营账号另配
#   reviewer 角色（与创作者隔离，评审端点 requireReviewer 门禁 + 禁创作者自审，见 50 §2.6）。
#
# ⚠️ canonical issuer 铁律（Codex#11-r4）：LOGTO_ISSUER 是单一权威值——
#   ① Logto 铸 token 的 iss（= {LOGTO_ENDPOINT}/oidc）；② API 验签断言的 iss。两者必须完全相等。
#   - 本机直跑（本文件）：API 在宿主、走 host-published 端口，三处都用 localhost:3001。
#     故 LOGTO_ENDPOINT=http://localhost:3001 / LOGTO_ISSUER=http://localhost:3001/oidc，自洽。
#   - 全栈 compose：API 在 compose 网内、按服务名访问 logto——必须改用 .env.compose.example
#     （issuer=http://logto:3001/oidc），否则容器内 /ready 与 JWKS 会打到 localhost = 打到自己。
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_ISSUER=http://localhost:3001/oidc
LOGTO_JWKS_URI=http://localhost:3001/oidc/jwks
# [app] Logto application 凭据（本机直跑也需填真实值才能完成登录回调）。
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_REDIRECT_URI=http://localhost/api/v1/auth/callback
# [app] JWT 受众 = 本服务 API resource indicator（Logto API resource，10-auth §4.1）。
#   dev 留空 = 不强校 aud（仅本机直跑可空；生产/compose 无条件校 aud，见 .env.compose.example）。
LOGTO_AUDIENCE=

# ───────────────────────── LLM Gateway（70 §8.3，degraded 不计 /ready）─────────────────────────
# [app] 上游 AI 网关凭据（OpenRouter / Anthropic）。空值不阻塞启动（骨架回落默认）。
ANTHROPIC_API_KEY=

# ───────────────────────── 仅 dev/test 种子登录（live 测试拿有效会话，绝不上生产）─────────────────────────
# 安全双守卫：NODE_ENV != production 【且】DEV_LOGIN_ENABLED=true 时才启用 POST /api/v1/auth/dev-login。
#   生产模式即便误配 DEV_LOGIN_ENABLED=true，loadEnv 也强制关回 false（端点不注册 → 404）。
# DEV_SESSION_SECRET：dev 会话 HS256 签名密钥（应用侧自签，与 Logto 无关）。无默认值——未配则即便开关开也不可用。
#   用法（开启后）：
#     curl -i -X POST http://localhost:3000/api/v1/auth/dev-login            # 默认种子创作者 Wayne / creator
#     curl -i -X POST http://localhost:3000/api/v1/auth/dev-login \
#          -H 'content-type: application/json' -d '{"email":"rev@dev.local","role":"reviewer"}'
#   响应种 cb_session cookie（httpOnly/SameSite=Lax）+ 返 MeView；带该 cookie 即可跑 requireAuth/SSE 受保护链路。
DEV_LOGIN_ENABLED=false
DEV_SESSION_SECRET=
