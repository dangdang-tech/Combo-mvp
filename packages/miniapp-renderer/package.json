{
  "name": "@cb/miniapp-renderer",
  "version": "0.0.0",
  "private": true,
  "description": "经验体 mini-app 的受限 UI 渲染器：runtime agent 输出白名单组件 JSON（zod 校验），渲染器映射为 @cb/ds 组件树；非法输入降级为错误卡片，绝不执行任意代码",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema/miniapp-ui.schema.json": "./schema/miniapp-ui.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit false",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@cb/ds": "workspace:*",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
