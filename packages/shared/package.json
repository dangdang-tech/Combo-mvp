{
  "name": "@cb/shared",
  "version": "0.0.0",
  "private": true,
  "description": "契约脊柱 + 各域 DTO/zod schema/错误信封/SSE 协议/常量/OpenAPI 真源（Phase 3/4 直接 import）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi/index.d.ts",
      "default": "./dist/openapi/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit false",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:gen": "tsc -b && node dist/openapi/generate.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "openapi3-ts": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
