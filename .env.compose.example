# 全栈 compose 起栈用环境变量（O-02/O-04 · 本编排即生产栈，业务容器 NODE_ENV=production）。
# 复制为 .env 后【必须填全部密钥】（compose 的 ${VAR:?} 未设即中止启动）。
# 本机直跑请改用 .env.local.example（localhost 访问、dev 可留空 aud）。
#
# ⚠️ 生产无默认密钥铁律（Codex#13 + r5）：本文件所有密钥项【留空】，由你填强随机值。
#   - compose 的 ${VAR:?} 对空值同样报错中止（空串不满足 :?），不会静默注入。
#   - 即便你填了，scripts/start.sh 的弱默认守卫也会拒绝 agora/minioadmin/postgres 等已知弱默认。
#   - 故示例文件【不带任何可用默认密钥】，杜绝「复制即生产、绕过无默认密钥」。

# ───────────────────────── 进程通用 ─────────────────────────
NODE_ENV=production
LOG_LEVEL=info
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ───────────────────────── PostgreSQL（密钥必填，留空报错）─────────────────────────
# [compose] postgres 容器初始化超级用户/库；业务/Logto 连接串由 compose 用这三项拼装。
#   ⚠️ 留空：填强密钥。禁用 agora / postgres 等弱默认（start.sh 守卫会拒）。
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# 业务连接串由 compose 内部用上面三项拼 postgres://USER:PASS@postgres:5432/DB，本文件无需单列 DATABASE_URL。

# ───────────────────────── Redis 双实例（compose 服务名，无密钥）─────────────────────────
# [compose] compose 网内按服务名访问；端口容器内统一 6379（host 映射 6379/6380 见 compose）。
REDIS_QUEUE_URL=redis://redis_queue:6379/0
REDIS_HOT_URL=redis://redis_hot:6379/0

# ───────────────────────── ObjectStore / MinIO（密钥必填，留空报错）─────────────────────────
# [compose] 同时用作 MinIO root 凭据与建桶脚本凭据。compose 网内 endpoint = http://minio:9000。
#   ⚠️ 留空：填强密钥。禁用 minioadmin 弱默认（start.sh 守卫会拒）。
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ───────────────────────── Logto 自托管（compose 网络 issuer 自洽）─────────────────────────
# ⚠️ canonical issuer 铁律（Codex#11-r4）：API 在 compose 网内、按服务名访问 logto。
#   三处必须完全相等且都用 compose 服务名 logto:3001——
#     ① Logto 铸 token 的 iss（= ENDPOINT/oidc）；② API 验签断言的 iss；③ logto healthcheck 断言的 iss。
#   绝不用 localhost:3001：那会让 API 容器内 /ready 与 JWKS 打到自己（容器内 localhost ≠ logto 容器）。
LOGTO_ENDPOINT=http://logto:3001
LOGTO_ISSUER=http://logto:3001/oidc
LOGTO_JWKS_URI=http://logto:3001/oidc/jwks
# [compose] logto 容器 admin 端点 + alteration 一次性 job 目标版本（CI=true 非交互，避免卡住）。
LOGTO_ADMIN_ENDPOINT=http://logto:3002
LOGTO_DB_ALTERATION_TARGET=next
# [app] Logto application 凭据 + 回调（生产【必填】，留空 compose 报错中止）。
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_REDIRECT_URI=http://localhost/api/v1/auth/callback
# [app] JWT 受众 = 本服务 API resource indicator。生产【必填】：api 无条件校 aud，缺则启动失败/拒所有 token。
LOGTO_AUDIENCE=

# ───────────────────────── LLM Gateway（degraded 不计 /ready，全部可留空）─────────────────────────
# [app] 上游 AI 网关。所有 LLM 项空值都不阻塞启动（degraded 只降级、不计 /ready，唯一允许空的密钥族）。
#
# provider 选择：显式 LLM_PROVIDER 优先；不填则按「哪个 key 在」自动判定
#   （有 OPENROUTER_API_KEY 而无 ANTHROPIC_API_KEY → openrouter；否则 anthropic）。
#   anthropic | openrouter；留空走自动判定。
LLM_PROVIDER=
# Anthropic 直连密钥（provider=anthropic 时用）。留空 → degraded。
ANTHROPIC_API_KEY=
# OpenRouter（OpenAI 兼容）密钥 sk-or-...（provider=openrouter 时用）。留空 → degraded。
OPENROUTER_API_KEY=
# OpenAI 兼容网关基址（仅 openrouter provider 用）。默认 OpenRouter，可不填。
LLM_BASE_URL=https://openrouter.ai/api/v1
# 模型覆盖。留空 → 按 provider 默认（anthropic→claude-opus-4-8，openrouter→anthropic/claude-3.7-sonnet）。
LLM_MODEL=
